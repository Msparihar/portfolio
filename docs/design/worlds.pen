                      "fill": "$gr-rubric",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "“Aua, lumen — burn low, and stay near.”",
                      "lineHeight": 1.2,
                      "textAlign": "center",
                      "fontFamily": "$gr-body",
                      "fontSize": 18,
                      "fontWeight": "normal",
