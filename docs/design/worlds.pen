                    {
                      "type": "text",
                      "id": "Rt5K8",
                      "name": "subject",
                      "fill": "#33442f",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "On the matter of the missing plums",
                      "lineHeight": 1.1,
                      "fontFamily": "Newsreader",
                      "fontSize": 30,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    },
                    {
                      "type": "rectangle",
                      "id": "HDqLf",
                      "name": "readHair",
                      "fill": "#33442f14",
                      "width": "fill_container",
                      "height": 1
                    },
                    {
                      "type": "frame",
                      "id": "Iu4AU",
                      "name": "letterBody",
                      "width": "fill_container",
                      "height": "fill_container",
                      "layout": "vertical",
                      "gap": 14,
                      "children": [
                        {
                          "type": "text",
                          "id": "k3WUr",
                          "name": "p0",
                          "fill": "#33442f",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Dear gardener,",
                          "lineHeight": 1.5,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vYwQ4",
                          "name": "p1",
                          "fill": "#46583f",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "I will be honest, for the moon is bright and honesty comes easy on nights like this. The three plums that vanished from your lowest branch did not fall to the wind. They fell, rather, to me.",
                          "lineHeight": 1.5,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "C0z6uN",
                          "name": "p2",
                          "fill": "#46583f",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "In my defense, they were the ripest I have ever smelled, and a fox is only a fox. I have left something in return at the foot of the tree — a smooth river stone I have carried for a season. It is not a plum, but it is the most precious thing I own.",
                          "lineHeight": 1.5,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "V3UNp",
                          "name": "p3",
                          "fill": "#46583f",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "If you will forgive me, I would like to sit with you at dusk and watch the fireflies. I promise to keep my paws to myself.",
                          "lineHeight": 1.5,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "OGE46",
                          "name": "p4",
                          "fill": "#46583f",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Ever yours, and a little ashamed,",
                          "lineHeight": 1.5,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "S7SBE",
                          "name": "sign",
                          "fill": "#33442f",
                          "content": "Vesper",
                          "fontFamily": "Newsreader",
                          "fontSize": 19,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        }
                      ]
