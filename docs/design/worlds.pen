                },
                {
                  "type": "frame",
                  "id": "ko8vU",
                  "name": "Left Divider",
                  "width": "fill_container",
                  "gap": 8,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "rectangle",
                      "id": "xbu4k",
                      "name": "Div Left Line",
                      "fill": {
                        "type": "gradient",
                        "gradientType": "linear",
