                    },
                    {
                      "type": "rectangle",
                      "id": "OEIVC",
                      "name": "Div Right Line",
                      "fill": {
                        "type": "gradient",
                        "gradientType": "linear",
                        "enabled": true,
                        "rotation": 90,
                        "size": {
                          "height": 1
                        },
                        "colors": [
                          {
                            "color": "#c9a84c",
                            "position": 0
                          },
                          {
                            "color": "#c9a84c00",
                            "position": 1
                          }
                        ]
                      },
                      "width": "fill_container",
                      "height": 1
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "MIRJo",
                  "name": "Left Body Para 1",
                  "fill": "#2a1a0a",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Great Erdtree, once radiant above the Lands Between, now weeps golden cinders into the ashen sky. I write this from the ruins of Stormveil — my hands still trembling from the Shardbearer's wrath. The grace that guides me falters with each stride forward, yet I press on.",
                  "lineHeight": 1.65,
                  "fontFamily": "Crimson Text",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "kRS6b",
                  "name": "Left Body Para 2",
                  "fill": "#2a1a0a",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "They call us Tarnished — stripped of grace, forsaken by the Elden Ring itself. Yet here I stand, quill in hand, recording what the scholars dared not: that the fracture was not fate, but folly.",
                  "lineHeight": 1.65,
                  "fontFamily": "Crimson Text",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Xin8i",
                  "name": "Left Body Para 3",
                  "fill": "#5a3e20",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\"Let the grace guide thee, Tarnished. To the Lands Between, to the Elden Ring, and to thy destined fate.\"",
                  "lineHeight": 1.55,
                  "fontFamily": "Crimson Text",
                  "fontSize": 14,
                  "fontWeight": "normal",
                  "fontStyle": "italic"
                },
                {
                  "type": "text",
                  "id": "bgeCz",
                  "name": "Left Bottom Ornament",
                  "fill": "#c9a84c70",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "━━━━━━━━━ ✦ ━━━━━━━━━",
                  "textAlign": "center",
                  "fontFamily": "Geist Mono",
