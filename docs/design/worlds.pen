                    {
                      "type": "text",
                      "id": "qSR6f",
                      "name": "lore",
                      "fill": "$gr-ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A small domestic working, taught first to children afraid of the dark. Trace the rune of warmth upon any cold hearth, speak the words once, and a low amber light will hold through the night — never enough to read by, always enough to feel less alone. The fire it kindles cannot spread, cannot burn, and asks only to be remembered come morning.",
                      "lineHeight": 1.5,
                      "textAlign": "justify",
                      "fontFamily": "$gr-body",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "kcJYk",
                      "name": "components",
                      "fill": "$gr-ink-soft",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Components — a dry birch twig, one held breath, the memory of a warm room.",
                      "lineHeight": 1.35,
                      "textAlign": "center",
                      "fontFamily": "$gr-body",
                      "fontSize": 12,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
