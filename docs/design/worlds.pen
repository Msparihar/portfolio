                    {
                      "type": "text",
                      "id": "y16hmL",
                      "name": "method",
                      "fill": "$gr-ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Press the seed into the warmed earth at dusk, no deeper than a knuckle, and cover it as you would tuck in a child. Trace the rune of greening above the soil, breathe the words once, and leave it be — coaxing, never commanding.",
                      "lineHeight": 1.55,
                      "fontFamily": "$gr-body",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "dYldf",
                      "name": "method-2",
                      "fill": "$gr-ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "By morning a pale shoot will have turned its face toward you, asking after the light. Greet it kindly; it remembers who woke it.",
                      "lineHeight": 1.55,
                      "fontFamily": "$gr-body",
                      "fontSize": 15,
                      "fontWeight": "normal"
